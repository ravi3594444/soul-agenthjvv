# Opportunity Engine v4 — Environment Variables

# ── Supabase (REQUIRED) ───────────────────────────────────────────────────────
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ── Telegram (REQUIRED) ───────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── LLM Keys (add at least one) ──────────────────────────────────────────────
GROQ_API_KEY=
MISTRAL_API_KEY=
GEMINI_API_KEY=
TOGETHER_API_KEY=
OPENROUTER_API_KEY=

# ── Optional search APIs ──────────────────────────────────────────────────────
TAVILY_API_KEY=
SERPER_API_KEY=

# ── Pipeline thresholds ───────────────────────────────────────────────────────
ALERT_THRESHOLD=7        # AI tools (max 16)
HACKATHON_THRESHOLD=6    # Hackathons (max 20)
LEAD_THRESHOLD=6         # Leads (max 10)
RECENCY_DAYS=7
